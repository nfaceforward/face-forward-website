<script>
// ====== ROUTER / MULTI-PAGE SPA ENGINE ======
let currentPage='home';
const pageHistory=[];

function goTo(page){
  if(page===currentPage)return;
  // Analytics: track page view
  trackEvent('page_view',{page});
  // Hide current
  document.querySelectorAll('.page').forEach(p=>{p.classList.remove('active');p.style.display='none';p.style.opacity='0'});
  // Show target
  const target=document.getElementById('page-'+page);
  if(target){
    target.style.display='block';
    setTimeout(()=>{target.style.opacity='1';target.classList.add('active')},10);
    target.classList.add('page-enter');
    setTimeout(()=>target.classList.remove('page-enter'),600);
  }
  currentPage=page;
  pageHistory.push(page);
  window.scrollTo({top:0,behavior:'smooth'});
  // Update nav active state
  document.querySelectorAll('.nav-links a').forEach(a=>a.classList.remove('active'));
  document.querySelectorAll('.nav-links a').forEach(a=>{if(a.textContent.toLowerCase().includes(page))a.classList.add('active')});
  // Re-observe animations
  setTimeout(initObs,200);
  // Update URL
  history.pushState({page},'','#'+page);
  // Update title for SEO
  const titles={home:'Face Forward Agency | Full-Service Marketing for MedSpas & Wellness',about:'About Us | Face Forward Agency',services:'Services | Face Forward Agency',portfolio:'Portfolio & Case Studies | Face Forward Agency',process:'Our Process | Face Forward Agency',results:'Client Results | Face Forward Agency',contact:'Get Your Free Growth Audit | Face Forward Agency'};
  document.title=titles[page]||titles.home;
}
// Handle browser back/forward
window.addEventListener('popstate',e=>{if(e.state&&e.state.page)goTo(e.state.page)});
// Handle initial hash
window.addEventListener('DOMContentLoaded',()=>{const h=location.hash.replace('#','');if(h&&document.getElementById('page-'+h))goTo(h)});

// ====== ANALYTICS ENGINE ======
const analytics={views:[],events:[],leads:[],sessions:{start:Date.now(),pages:[],scrollDepths:{},timeOnPage:{}}};

function trackEvent(type,data={}){
  const evt={type,data,time:Date.now(),page:currentPage};
  analytics.events.push(evt);
  analytics.sessions.pages.push(currentPage);
  // Store in sessionStorage for persistence
  try{sessionStorage.setItem('ff_analytics',JSON.stringify(analytics))}catch(e){}
  // Console log for debugging (remove in production, replace with your endpoint)
  console.log('[FF Analytics]',type,data);
}

// Track scroll depth per page
let maxScroll={};
window.addEventListener('scroll',()=>{
  const depth=Math.round((window.scrollY/(document.body.scrollHeight-window.innerHeight))*100);
  if(!maxScroll[currentPage]||depth>maxScroll[currentPage]){
    maxScroll[currentPage]=depth;
    analytics.sessions.scrollDepths[currentPage]=depth;
  }
});

// Track time on page
let pageStartTime=Date.now();
setInterval(()=>{
  const elapsed=Math.round((Date.now()-pageStartTime)/1000);
  analytics.sessions.timeOnPage[currentPage]=elapsed;
},5000);

// ====== LEAD CAPTURE ENGINE ======
function captLead(e,source){
  e.preventDefault();
  const form=e.target;
  const data={};
  new FormData(form).forEach((v,k)=>{data[k]=v});
  data.source=source;
  data.timestamp=new Date().toISOString();
  data.page=currentPage;
  data.sessionDuration=Math.round((Date.now()-analytics.sessions.start)/1000);
  data.pagesViewed=[...new Set(analytics.sessions.pages)];
  data.scrollDepths={...analytics.sessions.scrollDepths};
  
  // Store lead
  analytics.leads.push(data);
  try{
    const existing=JSON.parse(localStorage.getItem('ff_leads')||'[]');
    existing.push(data);
    localStorage.setItem('ff_leads',JSON.stringify(existing));
  }catch(e){}
  
  trackEvent('lead_captured',{source,fields:Object.keys(data).length});
  
  // Visual feedback
  const btn=form.querySelector('button[type="submit"],.fsubmit,.popup-submit');
  if(btn){
    const orig=btn.textContent;
    btn.textContent='✓ Submitted Successfully!';
    btn.style.background='#2C7A4B';btn.style.color='#fff';
    setTimeout(()=>{btn.textContent=orig;btn.style.background='';btn.style.color='';form.reset()},3000);
  }
  // Close popup if applicable
  if(source==='quiz')setTimeout(()=>closeP(1),2000);
  if(source==='urgency')setTimeout(()=>closeP(2),2000);
}

// ====== TIMED POPUP ENGINE ======
let p1Shown=false,p2Shown=false;
setTimeout(()=>{
  if(!p1Shown&&!analytics.leads.length){
    document.getElementById('popup1').classList.add('act');
    p1Shown=true;
    trackEvent('popup_shown',{popup:1,trigger:'45s_timer'});
  }
},45000);
setTimeout(()=>{
  if(!p2Shown&&analytics.leads.length===0){
    document.getElementById('popup2').classList.add('act');
    p2Shown=true;
    trackEvent('popup_shown',{popup:2,trigger:'3min_timer'});
  }
},180000);

function closeP(n){
  document.getElementById('popup'+n).classList.remove('act');
  trackEvent('popup_closed',{popup:n});
}

// ====== SCROLL & NAV ======
window.addEventListener('scroll',()=>{
  const n=document.getElementById('nav');
  const s=document.getElementById('stickyCta');
  if(window.scrollY>100){n.classList.add('scrolled');s.classList.add('vis')}
  else{n.classList.remove('scrolled');s.classList.remove('vis')}
});

// ====== INTERSECTION OBSERVER ======
function initObs(){
  const obs=new IntersectionObserver(entries=>{
    entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('vis');trackEvent('section_visible',{el:e.target.className.split(' ')[0]})}});
  },{threshold:.1});
  document.querySelectorAll('.fu,.growth-card').forEach(el=>obs.observe(el));
}
initObs();

// ====== COUNTER ANIMATION ======
function animateCounters(){
  document.querySelectorAll('.counter').forEach(c=>{
    if(c.dataset.animated)return;
    const rect=c.getBoundingClientRect();
    if(rect.top<window.innerHeight&&rect.bottom>0){
      c.dataset.animated='1';
      const target=parseInt(c.dataset.target);
      let current=0;
      const step=target/60;
      const timer=setInterval(()=>{
        current+=step;
        if(current>=target){current=target;clearInterval(timer)}
        c.textContent=Math.round(current);
      },25);
    }
  });
}
window.addEventListener('scroll',animateCounters);
setInterval(animateCounters,500);

// ====== FAQ TOGGLE ======
function togFaq(btn){
  const item=btn.parentElement;
  document.querySelectorAll('.faq-item').forEach(i=>{if(i!==item)i.classList.remove('open')});
  item.classList.toggle('open');
  trackEvent('faq_toggle',{question:btn.textContent.trim().substring(0,40)});
}

// ====== MOBILE NAV ======
function toggleMobile(){
  document.getElementById('mobileNav').classList.toggle('open');
}

// ====== HEATMAP TRACKER (lightweight) ======
document.addEventListener('click',e=>{
  trackEvent('click',{x:e.clientX,y:e.clientY,target:e.target.tagName,text:(e.target.textContent||'').substring(0,30),page:currentPage});
});

// ====== SESSION INIT ======
trackEvent('session_start',{
  referrer:document.referrer,
  userAgent:navigator.userAgent,
  screen:screen.width+'x'+screen.height,
  timestamp:new Date().toISOString()
});

// ====== UTM PARAMETER CAPTURE ======
const urlParams=new URLSearchParams(window.location.search);
const utmData={};
['utm_source','utm_medium','utm_campaign','utm_term','utm_content'].forEach(p=>{
  if(urlParams.get(p))utmData[p]=urlParams.get(p);
});
if(Object.keys(utmData).length){
  trackEvent('utm_captured',utmData);
  try{sessionStorage.setItem('ff_utm',JSON.stringify(utmData))}catch(e){}
}

// ====== SEO: STRUCTURED DATA ======
const schema=document.createElement('script');
schema.type='application/ld+json';
schema.textContent=JSON.stringify({"@context":"https://schema.org","@type":"MarketingAgency","name":"Face Forward Agency","description":"Full-service marketing agency specializing in medspas, plastic surgery, IV clinics, dental offices, gyms, and wellness brands. Beyond social media — complete marketing ecosystems.","url":"https://faceforwardagency.com","areaServed":"US","serviceType":["MedSpa Marketing","Plastic Surgery Marketing","Wellness Brand Marketing","Dental Marketing","Gym Marketing","Brand Strategy","Social Media Marketing","SEO","Lead Generation","Client Retention","Email Marketing","Paid Advertising"],"priceRange":"$$-$$$","knowsAbout":["Medical Aesthetics Marketing","Patient Retention","HIPAA Compliant Marketing","Local SEO","Conversion Rate Optimization"]});
document.head.appendChild(schema);
</script>
