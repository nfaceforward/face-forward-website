<style>
:root{--burgundy:#722F37;--burgundy-dark:#5A252C;--burgundy-light:#8B3A44;--gold:#C5A355;--gold-light:#D4B76A;--gold-dark:#A8893E;--ivory:#E8DCC8;--cream:#F5F0E8;--charcoal:#2C2C2A;--charcoal-light:#4A4A47;--rose:#8B3A44;--white:#FDFCFA;--font-h:'Cormorant Garamond',Georgia,serif;--font-b:'Montserrat','Helvetica Neue',sans-serif}
*{margin:0;padding:0;box-sizing:border-box}html{scroll-behavior:smooth;font-size:16px}body{font-family:var(--font-b);color:var(--charcoal);background:var(--white);overflow-x:hidden}a{text-decoration:none;color:inherit}ul{list-style:none}img{max-width:100%;display:block}

/* MARBLE TEXTURES */
.marble-l{background-color:var(--cream);background-image:url("data:image/svg+xml,%3Csvg width='800' height='800' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='m'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.018' numOctaves='5' seed='2' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23m)' opacity='0.06'/%3E%3C/svg%3E");background-size:cover}
.marble-d{background-color:var(--charcoal);background-image:url("data:image/svg+xml,%3Csvg width='800' height='800' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='m'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.015' numOctaves='5' seed='8'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23m)' opacity='0.08'/%3E%3C/svg%3E");background-size:cover}
.marble-b{background-color:var(--burgundy);background-image:url("data:image/svg+xml,%3Csvg width='800' height='800' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='m'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.02' numOctaves='4' seed='5'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23m)' opacity='0.07'/%3E%3C/svg%3E");background-size:cover}
/* BW marble accent */
.marble-bw{background-image:url("data:image/svg+xml,%3Csvg width='600' height='600' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='bw'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.008 0.015' numOctaves='6' seed='42'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3CfeComponentTransfer%3E%3CfeFuncR type='table' tableValues='0.92 0.96 1 0.93'/%3E%3CfeFuncG type='table' tableValues='0.90 0.94 0.98 0.91'/%3E%3CfeFuncB type='table' tableValues='0.87 0.91 0.95 0.88'/%3E%3C/feComponentTransfer%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23bw)' opacity='0.4'/%3E%3C/svg%3E");background-size:cover}
.marble-cream-accent{position:relative;overflow:hidden}.marble-cream-accent::before{content:'';position:absolute;top:0;left:0;width:100%;height:100%;background-image:url("data:image/svg+xml,%3Csvg width='900' height='400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='ca'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.01 0.02' numOctaves='5' seed='99'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23ca)' opacity='0.04'/%3E%3C/svg%3E");background-size:cover;pointer-events:none;z-index:0}

/* LAYOUT */
.ctn{max-width:1200px;margin:0 auto;padding:0 24px}.sp{padding:100px 0}.tc{text-align:center}.rel{position:relative;z-index:1}
.eye{font-family:var(--font-b);font-size:11px;font-weight:600;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:16px;display:inline-flex;align-items:center;gap:12px}.eye::before,.eye::after{content:'';width:30px;height:1px;background:linear-gradient(90deg,transparent,var(--gold))}.eye::after{background:linear-gradient(90deg,var(--gold),transparent)}
.sh{font-family:var(--font-h);font-size:clamp(32px,5vw,52px);font-weight:400;line-height:1.15;color:var(--charcoal);margin-bottom:20px}.sh em{font-style:italic;color:var(--burgundy)}
.ss{font-size:16px;font-weight:300;line-height:1.7;color:var(--charcoal-light);max-width:600px}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:8px;padding:16px 36px;font-family:var(--font-b);font-size:13px;font-weight:600;letter-spacing:2px;text-transform:uppercase;border:none;cursor:pointer;transition:all .4s cubic-bezier(.25,.46,.45,.94);position:relative;overflow:hidden}
.btn::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.15),transparent);transition:left .6s}.btn:hover::before{left:100%}
.btn-p{background:var(--burgundy);color:var(--cream)}.btn-p:hover{background:var(--burgundy-dark);transform:translateY(-2px);box-shadow:0 8px 30px rgba(114,47,55,.3)}
.btn-g{background:linear-gradient(135deg,var(--gold),var(--gold-light));color:var(--charcoal)}.btn-g:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(197,163,85,.4)}
.btn-o{background:transparent;color:var(--cream);border:1px solid var(--gold)}.btn-o:hover{background:var(--gold);color:var(--charcoal)}
.btn-gh{background:transparent;color:var(--burgundy);border:1px solid var(--burgundy)}.btn-gh:hover{background:var(--burgundy);color:var(--cream)}
.btn svg{width:16px;height:16px}

/* NAV */
nav{position:fixed;top:0;left:0;width:100%;z-index:1000;padding:20px 0;transition:all .4s;background:transparent}
nav.scrolled{background:rgba(253,252,250,.95);backdrop-filter:blur(20px);box-shadow:0 1px 0 rgba(197,163,85,.15);padding:14px 0}
nav .ctn{display:flex;justify-content:space-between;align-items:center}
.nav-logo{font-family:var(--font-b);font-size:13px;font-weight:700;letter-spacing:4px;text-transform:uppercase;color:var(--burgundy);cursor:pointer}.nav-logo span{color:var(--gold)}
.nav-links{display:flex;align-items:center;gap:28px}
.nav-links a{font-size:11px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:var(--charcoal-light);transition:color .3s;cursor:pointer;position:relative}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;background:var(--gold);transition:width .3s}
.nav-links a:hover{color:var(--burgundy)}.nav-links a:hover::after{width:100%}
.nav-links a.active{color:var(--burgundy)}.nav-links a.active::after{width:100%}
.nav-cta{padding:10px 24px!important;font-size:11px!important}
.mobile-menu{display:none;background:none;border:none;cursor:pointer;z-index:1001}.mobile-menu span{display:block;width:24px;height:1.5px;background:var(--charcoal);margin:5px 0;transition:.3s}
.mobile-nav{position:fixed;top:0;right:-100%;width:280px;height:100vh;background:var(--white);z-index:1000;padding:80px 32px;transition:right .4s;box-shadow:-4px 0 30px rgba(0,0,0,.1)}
.mobile-nav.open{right:0}
.mobile-nav a{display:block;font-size:14px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:var(--charcoal);padding:16px 0;border-bottom:1px solid rgba(197,163,85,.15);cursor:pointer}

/* FLOATING SHAPES */
.fshapes{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;overflow:hidden;z-index:0}
.fs{position:absolute;border:1px solid;opacity:0;animation:fsf 12s ease-in-out infinite}
.fs-c{border-radius:50%}.fs-d{transform:rotate(45deg)}
.fs.a{width:80px;height:80px;border-color:rgba(197,163,85,.12);top:15%;left:8%;animation-delay:0s}
.fs.b{width:120px;height:120px;border-color:rgba(114,47,55,.08);top:60%;right:5%;animation-delay:2s}
.fs.c{width:50px;height:50px;border-color:rgba(197,163,85,.15);top:30%;right:15%;animation-delay:4s}
.fs.d{width:180px;height:180px;border-color:rgba(114,47,55,.06);bottom:10%;left:15%;animation-delay:1s}
.fs.e{width:40px;height:40px;border-color:rgba(197,163,85,.2);top:70%;left:25%;animation-delay:3s}
@keyframes fsf{0%,100%{opacity:0;transform:translateY(20px)}20%{opacity:1}80%{opacity:1}50%{transform:translateY(-20px) rotate(5deg)}}

/* GOLD PARTICLES */
.gp{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;overflow:hidden}
.gp i{position:absolute;width:3px;height:3px;background:var(--gold);border-radius:50%;opacity:0;animation:pr 8s ease-in-out infinite}
.gp i:nth-child(1){left:10%;animation-delay:0s}.gp i:nth-child(2){left:25%;animation-delay:1.5s}.gp i:nth-child(3){left:45%;animation-delay:.8s}.gp i:nth-child(4){left:65%;animation-delay:2.2s}.gp i:nth-child(5){left:80%;animation-delay:3.1s}.gp i:nth-child(6){left:92%;animation-delay:1.1s}
@keyframes pr{0%{bottom:-10px;opacity:0}20%{opacity:.6}80%{opacity:.3}100%{bottom:100%;opacity:0;transform:scale(.3)}}

/* GOLD SEP */
.gsep{display:flex;align-items:center;justify-content:center;gap:16px;padding:20px 0}.gsep i{width:60px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent)}.gsep b{width:8px;height:8px;background:var(--gold);transform:rotate(45deg);font-weight:normal}

/* PAGE TRANSITIONS */
.page{display:none;opacity:0;transition:opacity .5s ease;min-height:100vh}.page.active{display:block;opacity:1}
.page-enter{animation:pageIn .6s ease forwards}
@keyframes pageIn{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

/* SCROLL ANIMATIONS */
.fu{opacity:0;transform:translateY(30px);transition:opacity .8s ease,transform .8s ease}.fu.vis{opacity:1;transform:translateY(0)}

/* ============ HERO ============ */
.hero{min-height:100vh;display:flex;align-items:center;position:relative;overflow:hidden}
.hero-bg{position:absolute;top:0;left:0;width:100%;height:100%;background:radial-gradient(ellipse at 70% 20%,rgba(197,163,85,.07) 0%,transparent 50%),radial-gradient(ellipse at 20% 80%,rgba(114,47,55,.05) 0%,transparent 50%),var(--cream);z-index:0}
.hero-bg::after{content:'';position:absolute;top:0;left:0;width:100%;height:100%;background-image:url("data:image/svg+xml,%3Csvg width='1200' height='900' xmlns='http://www.w3.org/2000/svg'%3E%3Cdefs%3E%3Cfilter id='hm'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.012 0.008' numOctaves='5' seed='3'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3C/defs%3E%3Crect width='100%25' height='100%25' filter='url(%23hm)' opacity='0.045'/%3E%3C/svg%3E");background-size:cover;mix-blend-mode:multiply}
.hero-veins{position:absolute;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none}
.hero-veins svg{width:100%;height:100%}
.hero .ctn{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;padding-top:100px;position:relative;z-index:2}
.hero-content{position:relative;z-index:2}
.hero-eyebrow{font-size:11px;font-weight:600;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:24px;display:flex;align-items:center;gap:12px}.hero-eyebrow::before{content:'';width:40px;height:1px;background:var(--gold)}
.hero h1{font-family:var(--font-h);font-size:clamp(42px,6vw,72px);font-weight:400;line-height:1.08;color:var(--charcoal);margin-bottom:24px}
.hero h1 em{font-style:italic;color:var(--burgundy);position:relative}.hero h1 em::after{content:'';position:absolute;bottom:2px;left:0;width:100%;height:8px;background:linear-gradient(90deg,rgba(197,163,85,.25),rgba(197,163,85,.05));z-index:-1}
.hero-sub{font-size:17px;font-weight:300;line-height:1.8;color:var(--charcoal-light);margin-bottom:40px;max-width:480px}
.hero-btns{display:flex;gap:16px;flex-wrap:wrap}
.hero-stats{display:flex;gap:40px;margin-top:56px;padding-top:32px;border-top:1px solid rgba(197,163,85,.3)}
.hero-stat b{display:block;font-family:var(--font-h);font-size:36px;font-weight:500;color:var(--burgundy)}.hero-stat small{font-size:12px;font-weight:500;letter-spacing:1px;color:var(--charcoal-light);margin-top:4px;display:block}
.hero-vis{position:relative;display:flex;justify-content:center;align-items:center}
.hero-card{width:100%;max-width:440px;aspect-ratio:3/4;position:relative;overflow:hidden;display:flex;align-items:flex-end;padding:40px;background:linear-gradient(160deg,rgba(197,163,85,.12) 0%,transparent 40%),linear-gradient(340deg,rgba(44,44,42,.5) 0%,transparent 60%),var(--burgundy)}
.hero-card::before{content:'';position:absolute;top:0;left:0;width:100%;height:100%;background-image:url("data:image/svg+xml,%3Csvg width='500' height='700' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='mc'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.025' numOctaves='5' seed='12'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23mc)' opacity='0.1'/%3E%3C/svg%3E");background-size:cover;mix-blend-mode:overlay}
.hero-card::after{content:'';position:absolute;top:30%;left:-10%;width:120%;height:1px;background:linear-gradient(90deg,transparent,rgba(197,163,85,.4),transparent);transform:rotate(-15deg)}
.hero-card-c{position:relative;z-index:2;color:var(--cream)}
.hero-card-ff{font-family:var(--font-h);font-size:120px;font-weight:300;color:rgba(197,163,85,.12);position:absolute;top:30px;right:30px;line-height:1;z-index:1}
.hero-card-tl{font-family:var(--font-h);font-size:28px;font-weight:400;font-style:italic;color:var(--gold);margin-bottom:12px}
.hero-card-tx{font-size:13px;font-weight:300;line-height:1.7;opacity:.8}
.hero-frame{position:absolute;top:-16px;left:-16px;width:calc(100% + 32px);height:calc(100% + 32px);border:1px solid rgba(197,163,85,.2);pointer-events:none;z-index:0}
.hero-badge{position:absolute;top:40px;right:-20px;background:linear-gradient(135deg,var(--gold),var(--gold-light));color:var(--charcoal);padding:14px 20px;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;box-shadow:0 12px 40px rgba(0,0,0,.15);animation:float 6s ease-in-out infinite;z-index:3}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}

/* MARQUEE */
.marq{padding:28px 0;border-top:1px solid rgba(197,163,85,.2);border-bottom:1px solid rgba(197,163,85,.2);overflow:hidden;background:var(--white)}
.marq-t{display:flex;gap:60px;animation:mscr 40s linear infinite;width:max-content}
.marq-i{font-size:12px;font-weight:500;letter-spacing:3px;text-transform:uppercase;color:var(--charcoal-light);white-space:nowrap;opacity:.5;display:flex;align-items:center;gap:60px}.marq-i::after{content:'';width:6px;height:6px;background:var(--gold);transform:rotate(45deg)}
@keyframes mscr{to{transform:translateX(-50%)}}

/* ============ PORTFOLIO SECTION ============ */
.port-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:60px}
.port-card{position:relative;overflow:hidden;aspect-ratio:4/3;cursor:pointer;border:1px solid rgba(197,163,85,.1)}
.port-img{width:100%;height:100%;object-fit:cover;transition:transform .6s}
.port-card:hover .port-img{transform:scale(1.05)}
.port-overlay{position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(44,44,42,.85));display:flex;flex-direction:column;justify-content:flex-end;padding:24px;transition:all .4s}
.port-card:hover .port-overlay{background:linear-gradient(180deg,transparent 20%,rgba(114,47,55,.9))}
.port-tag{font-size:10px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:6px}
.port-title{font-family:var(--font-h);font-size:22px;font-weight:400;color:var(--cream)}
.port-stat{font-size:12px;color:rgba(232,220,200,.7);margin-top:6px}
/* VISUAL GROWTH METRICS */
.growth-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-top:60px}
.growth-card{padding:32px 24px;text-align:center;border:1px solid rgba(197,163,85,.15);background:var(--white);transition:all .4s;position:relative;overflow:hidden}
.growth-card::before{content:'';position:absolute;bottom:0;left:0;width:100%;height:3px;background:linear-gradient(90deg,var(--gold),var(--burgundy));transform:scaleX(0);transition:transform .4s}.growth-card:hover::before{transform:scaleX(1)}
.growth-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(0,0,0,.06)}
.growth-num{font-family:var(--font-h);font-size:48px;font-weight:500;color:var(--burgundy);margin-bottom:4px}
.growth-num .counter{display:inline}
.growth-label{font-size:13px;font-weight:500;color:var(--charcoal-light);letter-spacing:1px}
.growth-bar{width:100%;height:4px;background:rgba(197,163,85,.15);border-radius:2px;margin-top:16px;overflow:hidden}
.growth-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--gold),var(--burgundy));width:0;transition:width 1.5s ease}
.growth-card.vis .growth-fill{width:var(--pct)}

/* ============ SERVICES GRID ============ */
.srv-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:60px}
.srv-card{padding:40px 32px;border:1px solid rgba(197,163,85,.15);transition:all .4s;position:relative;overflow:hidden;background:var(--white)}
.srv-card::before{content:'';position:absolute;top:0;left:0;width:100%;height:3px;background:linear-gradient(90deg,var(--gold),var(--burgundy));transform:scaleX(0);transform-origin:left;transition:transform .4s}.srv-card:hover::before{transform:scaleX(1)}
.srv-card::after{content:'';position:absolute;bottom:0;right:0;width:100px;height:100px;background:radial-gradient(circle,rgba(197,163,85,.06),transparent 70%);transition:all .4s}.srv-card:hover::after{width:200px;height:200px}
.srv-card:hover{border-color:rgba(197,163,85,.35);box-shadow:0 20px 60px rgba(0,0,0,.06);transform:translateY(-4px)}
.srv-n{font-family:var(--font-h);font-size:48px;font-weight:300;background:linear-gradient(135deg,var(--gold),rgba(197,163,85,.3));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:20px}
.srv-card h3{font-family:var(--font-h);font-size:24px;font-weight:500;color:var(--charcoal);margin-bottom:12px}
.srv-card p{font-size:14px;font-weight:300;line-height:1.7;color:var(--charcoal-light);margin-bottom:20px}
.srv-card li{font-size:13px;font-weight:400;color:var(--charcoal-light);padding:6px 0;border-bottom:1px solid rgba(0,0,0,.04);display:flex;align-items:center;gap:8px}
.srv-card li::before{content:'';width:6px;height:6px;background:var(--gold);transform:rotate(45deg);flex-shrink:0}

/* DIFF GRID */
.diff-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2px;margin-top:60px;background:rgba(197,163,85,.08)}
.diff-card{padding:48px 40px;background:var(--charcoal);transition:background .4s;position:relative;overflow:hidden}
.diff-card::after{content:'';position:absolute;top:-50%;right:-50%;width:100%;height:100%;background:radial-gradient(circle,rgba(197,163,85,.04),transparent 60%);transition:all .6s}.diff-card:hover::after{top:-30%;right:-30%}
.diff-icon{width:48px;height:48px;border:1px solid var(--gold);display:flex;align-items:center;justify-content:center;margin-bottom:24px;font-family:var(--font-h);font-size:20px;color:var(--gold);position:relative;z-index:1}
.diff-card h3{font-family:var(--font-h);font-size:24px;font-weight:400;color:var(--gold);margin-bottom:12px;position:relative;z-index:1}
.diff-card p{font-size:14px;font-weight:300;line-height:1.7;color:rgba(232,220,200,.7);position:relative;z-index:1}

/* AUDIENCE CARDS */
.aud-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:60px}
.aud-card{padding:44px 32px;position:relative;transition:all .4s;overflow:hidden;border:1px solid rgba(197,163,85,.1);background:radial-gradient(circle at bottom right,rgba(197,163,85,.04),transparent 60%),var(--cream)}
.aud-card::after{content:'';position:absolute;bottom:0;left:0;width:100%;height:3px;background:linear-gradient(90deg,var(--burgundy),var(--gold));transform:scaleX(0);transition:transform .4s}.aud-card:hover::after{transform:scaleX(1)}
